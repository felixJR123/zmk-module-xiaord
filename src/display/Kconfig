menu "Xiaord display options"

config XIAORD_BG_1
    bool "Background 1"
    default y if !XIAORD_BG_2 && !XIAORD_BG_3 && !XIAORD_BG_4

config XIAORD_BG_2
    bool "Background 2"
    default n

config XIAORD_BG_3
    bool "Background 3"
    default n

config XIAORD_BG_4
    bool "Local custom background"
    default n
    help
      Enable the local custom background slot. The build will use
      src/display/ui/bg/bg4.c when it exists. If it does not exist, the build
      will try to generate it from XIAORD_BG_4_SOURCE_DIR. If no local image is
      available, the firmware falls back to Background 1 so public builds still
      compile.

config XIAORD_BG_4_SOURCE_DIR
    string "Local folder for custom background source pictures"
    default ""
    depends on XIAORD_BG_4
    help
      Optional local folder containing JPG/PNG files. When XIAORD_BG_4 is
      enabled and bg4.c is missing, the build uses the first image in this
      folder to generate bg4.c and bg4.png. Leave empty to use an existing
      local bg4.c or fall back to Background 1.

config XIAORD_BG_5
    bool
    default n

config XIAORD_BG_6
    bool
    default n

config XIAORD_REMOVE_DATE_TIME
    bool "Remove date/time from home screen"
    default n
    help
      Remove the home screen date and time labels for cleaner photo backgrounds.
      The clock settings page remains available.

config XIAORD_DOUBLE_TAP_MS
    int "Home screen double-tap timeout in milliseconds"
    default 450
    range 100 2000
    help
      Maximum time between home screen taps to count as a double tap. Increase
      this if opening the shortcut button ring feels too difficult.

endmenu
