menu "Xiaord display options"

config XIAORD_BG_1
    bool "Background 1"
    default y if !XIAORD_BG_2 && !XIAORD_BG_3 && !XIAORD_BG_4

config XIAORD_BG_2
    bool "Background 2"
    default n

config XIAORD_BG_3
    bool "Background 3"
    default n

config XIAORD_BG_4
    bool "Keyboard repo custom background"
    default n
    help
      Enable the custom background slot. The build will use an existing local
      src/display/ui/bg/bg4.c when present. Otherwise, it will try to generate
      bg4.c from XIAORD_BG_4_SOURCE_DIR, the XIAORD_BG_4_SOURCE_DIR
      environment variable, or the default xiaord-bg folder in the keyboard
      config repo. If no image is available, the firmware falls back to
      Background 1 so public builds still compile.

config XIAORD_BG_4_SOURCE_DIR
    string "Custom background source picture folder"
    default ""
    depends on XIAORD_BG_4
    help
      Optional folder containing JPG/PNG files. Relative paths are resolved
      from the keyboard config repo. When XIAORD_BG_4 is enabled and bg4.c is
      missing, the build uses the first image in this folder to generate bg4.c
      and bg4.png. Leave empty to use xiaord-bg in the keyboard config repo,
      use the XIAORD_BG_4_SOURCE_DIR environment variable, or fall back to
      Background 1.

config XIAORD_BG_SD
    bool "SD card backgrounds"
    default n
    select DISK_ACCESS
    select FILE_SYSTEM
    select FAT_FILESYSTEM_ELM
    help
      Load 240x240 RGB565 background files from the microSD card instead of
      compiling photos into the firmware. Files are expected to be generated by
      tools/xiaord_sd_backgrounds.py and stored as bg001.rgb565, bg002.rgb565,
      etc. The firmware keeps only one active image in RAM and falls back to
      the selected compiled background if the SD card or converted files are
      unavailable.

config XIAORD_BG_SD_MOUNT_POINT
    string "SD card mount point"
    default "/SD:"
    depends on XIAORD_BG_SD
    help
      Filesystem mount point for the SD card.

config XIAORD_BG_SD_DIR
    string "SD card converted background directory"
    default "/xiaord-bg/converted"
    depends on XIAORD_BG_SD
    help
      Directory under the mount point containing bg001.rgb565, bg002.rgb565,
      etc.

config XIAORD_BG_SD_MAX_FILES
    int "Maximum SD backgrounds to index"
    default 999
    range 1 999
    depends on XIAORD_BG_SD
    help
      Maximum number of SD-card background files to scan and cycle through.

config XIAORD_BG_SD_ROTATE_MS
    int "SD background auto-rotate timeout in milliseconds"
    default 0
    range 0 86400000
    depends on XIAORD_BG_SD
    help
      Automatically advance to the next SD-card background after this many
      milliseconds. Set to 0 to disable automatic rotation.

config XIAORD_BG_SD_GESTURES
    bool "Use left/right slide gestures for SD backgrounds"
    default y
    depends on XIAORD_BG_SD
    help
      When enabled, slide left/right on the home screen cycle SD-card
      backgrounds instead of firing the normal left/right gesture bindings.

config XIAORD_BG_5
    bool "Deprecated custom background 2 (ignored)"
    default n
    help
      Deprecated compatibility option. Custom backgrounds now use only
      XIAORD_BG_4. This option is accepted so older keyboard configs that still
      set CONFIG_XIAORD_BG_5=n or y do not fail Kconfig parsing.

config XIAORD_BG_6
    bool "Deprecated custom background 3 (ignored)"
    default n
    help
      Deprecated compatibility option. Custom backgrounds now use only
      XIAORD_BG_4. This option is accepted so older keyboard configs that still
      set CONFIG_XIAORD_BG_6=n or y do not fail Kconfig parsing.

config XIAORD_REMOVE_DATE_TIME
    bool "Remove date/time from home screen"
    default n
    help
      Remove the home screen date and time labels for cleaner photo backgrounds.
      The clock settings page remains available.

config XIAORD_DOUBLE_TAP_MS
    int "Home screen double-tap timeout in milliseconds"
    default 450
    range 100 2000
    help
      Maximum time between home screen taps to count as a double tap. Increase
      this if opening the shortcut button ring feels too difficult.

endmenu
