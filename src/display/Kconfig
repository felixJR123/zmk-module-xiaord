menu "Xiaord background images"

config XIAORD_BG_1
    bool "Background 1"
    default y if !XIAORD_BG_2 && !XIAORD_BG_3 && !XIAORD_BG_4 && !XIAORD_BG_5 && !XIAORD_BG_6

config XIAORD_BG_2
    bool "Background 2"
    default n

config XIAORD_BG_3
    bool "Background 3"
    default n

config XIAORD_BG_4
    bool "Custom background 1"
    default n

config XIAORD_BG_5
    bool "Custom background 2"
    default n

config XIAORD_BG_6
    bool "Custom background 3"
    default n

config XIAORD_REMOVE_DATE_TIME
    bool "Remove date/time from home screen"
    default n
    help
      Remove the home screen date and time labels for cleaner photo backgrounds.
      The clock settings page remains available.

endmenu
